<Window x:Class="WireGuardCommand.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WireGuardCommand"
        xmlns:uc="clr-namespace:WireGuardCommand.Resources.UserControls"
        xmlns:vms="clr-namespace:WireGuardCommand.ViewModels"
        xmlns:v="clr-namespace:WireGuardCommand.Views"
        mc:Ignorable="d"
        Title="WireGuard Command" 
        MinHeight="480" MinWidth="800">

    <!-- Bind Views to ViewModels -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vms:ProjectNavigatorViewModel}">
            <v:ProjectNavigatorView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vms:ProjectViewModel}">
            <v:ProjectView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vms:ProjectNewViewModel}">
            <v:ProjectNewView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <ContentPresenter Content="{Binding NavService.CurrentView}"/>
    </Grid>
</Window>
