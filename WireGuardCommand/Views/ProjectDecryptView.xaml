<UserControl x:Class="WireGuardCommand.Views.ProjectDecryptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WireGuardCommand.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Vertical" Margin="0, 0, 0, 5">
                <TextBlock>This project is encrypted, enter the passphrase to decrypt it.</TextBlock>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0, 0, 0, 5">
                <TextBlock>Passphrase</TextBlock>
                <TextBox Text="{Binding EncryptionPhrase}"></TextBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0, 0, 0, 5">
                <Button Command="{Binding GoBackCommand}">Back</Button>
                <Button Command="{Binding DecryptProjectCommand}">Open</Button>
            </StackPanel>

            <StackPanel Orientation="Vertical">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontWeight="SemiBold" FontSize="24"></TextBlock>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
